############################################
# Secrets (never version)
############################################

shared/.env.secrets
*.env.local
*.key
*.pem
*.crt


############################################
# Stack runtime state (NEW)
############################################

state/
backups/
recovered_apps/
shared/service-catalog/services.json

# Traefik ACME certificates (runtime, contains private keys)
gateway/acme/


############################################
# General runtime data (never version)
############################################

**/data/
**/work/
**/conf/
**/downloads/
**/tmp/
**/cache/
**/logs/

**/*.log


############################################
# App config/runtime bind mounts
############################################

# Generic config directories (app state)
**/config/

# qBittorrentVPN runtime state
apps/qbittorrentvpn/gluetun/
apps/qbittorrentvpn/qbittorrent/

# MeTube runtime
apps/metube/downloads/


############################################
# WireGuard runtime (IMPORTANT FIX)
############################################

apps/qbittorrentvpn/wireguard-pia/wg0.conf
apps/qbittorrentvpn/wireguard-pia/port.dat


############################################
# Docker / system junk
############################################

.codex/
*.pid
*.sock
*.swp
*.bak
.DS_Store


############################################
# Keep infrastructure code versioned
############################################

# Scripts
!apps/qbittorrentvpn/scripts/
!apps/qbittorrentvpn/scripts/**

# Compose files
!**/compose.yml

# Stack tooling
!stack

# Per-app env files (non-secret)
**/.env
!apps/paperless/.env


############################################
# Transkun runtime
############################################

apps/transkun/data/
