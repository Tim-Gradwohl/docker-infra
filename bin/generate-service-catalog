#!/usr/bin/env python3
"""Generate a shared service catalog from Cloudflare Tunnel remote-managed ingress.

Reads Cloudflare tunnel data, extracts hostname-based ingress rules, merges optional
presentation metadata, and writes an atomically-updated JSON artifact that can be
consumed by the landing stack or other apps.
"""

from __future__ import annotations

import json
import os
import pathlib
import re
import sys
import tempfile
import urllib.error
import urllib.request
from datetime import datetime, timezone
from typing import Any, Dict, List, Tuple

API_BASE = "https://api.cloudflare.com/client/v4"
DEFAULT_OUTPUT = pathlib.Path("~/stacks/shared/service-catalog/services.json").expanduser()
DEFAULT_META = pathlib.Path("~/stacks/apps/landing/services.meta.json").expanduser()
DEFAULT_TIMEOUT = 20
USER_AGENT = "generate-service-catalog/1.0"


def env_required(name: str) -> str:
    value = os.environ.get(name)
    if not value:
        raise SystemExit(f"Missing required environment variable: {name}")
    return value


def env_path(name: str, default: pathlib.Path) -> pathlib.Path:
    raw = os.environ.get(name)
    return pathlib.Path(raw).expanduser() if raw else default


def env_int(name: str, default: int) -> int:
    raw = os.environ.get(name)
    if not raw:
        return default
    try:
        return int(raw)
    except ValueError as exc:
        raise SystemExit(f"Environment variable {name} must be an integer") from exc


def slugify_hostname(hostname: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", hostname.lower()).strip("-")


def cf_request(path: str, token: str, timeout: int) -> Dict[str, Any]:
    request = urllib.request.Request(
        f"{API_BASE}{path}",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "User-Agent": USER_AGENT,
        },
        method="GET",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"Cloudflare API error {exc.code} for {path}: {body}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"Cloudflare API request failed for {path}: {exc}") from exc

    if not payload.get("success", False):
        errors = payload.get("errors", [])
        raise RuntimeError(f"Cloudflare API reported failure for {path}: {errors}")

    return payload


def load_metadata(meta_path: pathlib.Path) -> Dict[str, Dict[str, Any]]:
    if not meta_path.exists():
        return {}
    try:
        with meta_path.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Metadata file is not valid JSON: {meta_path}: {exc}") from exc

    if not isinstance(data, dict):
        raise SystemExit(f"Metadata file must contain a JSON object keyed by hostname: {meta_path}")

    validated: Dict[str, Dict[str, Any]] = {}
    for hostname, value in data.items():
        if isinstance(hostname, str) and isinstance(value, dict):
            validated[hostname] = value
    return validated


def write_json_atomic(output_path: pathlib.Path, payload: Dict[str, Any]) -> None:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        mode="w",
        encoding="utf-8",
        dir=str(output_path.parent),
        prefix=f".{output_path.name}.",
        suffix=".tmp",
        delete=False,
    ) as tmp:
        json.dump(payload, tmp, indent=2, sort_keys=False)
        tmp.write("\n")
        temp_name = tmp.name
    os.replace(temp_name, output_path)


def extract_services(
    tunnels: List[Dict[str, Any]],
    account_id: str,
    token: str,
    timeout: int,
    metadata: Dict[str, Dict[str, Any]],
) -> Tuple[List[Dict[str, Any]], List[str]]:
    services: List[Dict[str, Any]] = []
    errors: List[str] = []

    for tunnel in tunnels:
        tunnel_id = tunnel.get("id")
        tunnel_name = tunnel.get("name") or "unknown"
        tunnel_status = tunnel.get("status")
        if not tunnel_id:
            errors.append(f"Skipped tunnel without id: {tunnel!r}")
            continue

        try:
            config_payload = cf_request(
                f"/accounts/{account_id}/cfd_tunnel/{tunnel_id}/configurations",
                token,
                timeout,
            )
        except RuntimeError as exc:
            errors.append(str(exc))
            continue

        ingress_rules = (
            config_payload.get("result", {})
            .get("config", {})
            .get("ingress", [])
        )
        if not isinstance(ingress_rules, list):
            errors.append(f"Tunnel {tunnel_name} ({tunnel_id}) returned non-list ingress config")
            continue

        for rule in ingress_rules:
            if not isinstance(rule, dict):
                continue
            hostname = rule.get("hostname")
            upstream = rule.get("service")
            if not hostname or not upstream:
                continue

            meta = metadata.get(hostname, {})
            service = {
                "id": meta.get("id") or slugify_hostname(hostname),
                "name": meta.get("name") or hostname,
                "hostname": hostname,
                "url": f"https://{hostname}",
                "service": upstream,
                "tunnel_id": tunnel_id,
                "tunnel_name": tunnel_name,
                "tunnel_status": tunnel_status,
                "source": "cloudflare",
                "published": True,
                "description": meta.get("description"),
                "icon": meta.get("icon"),
                "category": meta.get("category"),
                "order": meta.get("order", 1000),
                "tags": meta.get("tags", []),
                "notes": meta.get("notes"),
            }
            services.append(service)

    services.sort(key=lambda item: (item.get("order", 1000), item.get("name", ""), item.get("hostname", "")))
    return services, errors


def main() -> int:
    token = env_required("CLOUDFLARE_API_TOKEN")
    account_id = env_required("CLOUDFLARE_ACCOUNT_ID")
    output_path = env_path("CF_SERVICE_CATALOG_OUTPUT", DEFAULT_OUTPUT)
    meta_path = env_path("CF_SERVICE_CATALOG_META", DEFAULT_META)
    timeout = env_int("CF_SERVICE_CATALOG_TIMEOUT", DEFAULT_TIMEOUT)

    metadata = load_metadata(meta_path)
    tunnel_payload = cf_request(f"/accounts/{account_id}/cfd_tunnel", token, timeout)
    tunnels = tunnel_payload.get("result", [])
    if not isinstance(tunnels, list):
        raise SystemExit("Cloudflare tunnel list response had an unexpected format")

    services, errors = extract_services(tunnels, account_id, token, timeout, metadata)

    payload = {
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "source": "cloudflare_tunnel_remote_config",
        "account_id": account_id,
        "service_count": len(services),
        "tunnel_count": len(tunnels),
        "services": services,
        "errors": errors,
    }

    write_json_atomic(output_path, payload)
    print(f"Wrote {len(services)} services from {len(tunnels)} tunnels to {output_path}")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        raise SystemExit(130)
